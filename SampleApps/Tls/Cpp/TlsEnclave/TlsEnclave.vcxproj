  </ItemGroup>
  <PropertyGroup Label="Globals">
    <VCProjectVersion>17.0</VCProjectVersion>
    <Keyword>Win32Proj</Keyword>
    <ProjectGuid>{4382d3e4-8a0c-4128-a005-343441dce4b1}</ProjectGuid>
    <RootNamespace>TlsEnclave</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
    <ProjectName>TlsEnclave</ProjectName>
    <TlsSamplePlatformToolset Condition="'$(TlsSamplePlatformToolset)'==''">v145</TlsSamplePlatformToolset>
    <MbedTlsRoot Condition="'$(MbedTlsRoot)'==''">$(ProjectDir)..\..\external\mbedtls</MbedTlsRoot>
  </PropertyGroup>
  <PropertyGroup Label="EDL codegen props">
    <VbsEnclaveEdlPath>$(ProjectDir)..\..\TlsTransport.edl</VbsEnclaveEdlPath>
    <VbsEnclaveNamespace>TlsSample</VbsEnclaveNamespace>
    <VbsEnclaveVtl0ClassName>TlsSampleHost</VbsEnclaveVtl0ClassName>
    <VbsEnclaveVirtualTrustLayer>Enclave</VbsEnclaveVirtualTrustLayer>
    <VbsEnclaveConsumeCppSupportLib>true</VbsEnclaveConsumeCppSupportLib>
  </PropertyGroup>
  <PropertyGroup Label="Test signing certificate">
    <EnclaveCertName Condition="'$(EnclaveCertName)'==''">TlsSampleEnclaveCert</EnclaveCertName>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <PropertyGroup Label="Configuration" Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseDebugLibraries>true</UseDebugLibraries>
    <PlatformToolset>$(TlsSamplePlatformToolset)</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>
  <PropertyGroup Label="Configuration" Condition="'$(Configuration)|$(Platform)'=='Debug|ARM64'">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseDebugLibraries>true</UseDebugLibraries>
    <PlatformToolset>$(TlsSamplePlatformToolset)</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>
  <PropertyGroup Label="Configuration" Condition="'$(Configuration)'=='Release'">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>$(TlsSamplePlatformToolset)</PlatformToolset>
    <WholeProgramOptimization>true</WholeProgramOptimization>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <PropertyGroup>
    <OutDir>$(ProjectDir)bin\$(Platform)\$(Configuration)\</OutDir>
    <IntDir>$(ProjectDir)obj\$(Platform)\$(Configuration)\</IntDir>
    <TargetName>TlsEnclave</TargetName>
    <LinkIncremental>false</LinkIncremental>
    <UseGeneratedModuleDefinitionFile>false</UseGeneratedModuleDefinitionFile>
    <UseEnclave>true</UseEnclave>
    <GenerateDesktopDeployRecipeFile>false</GenerateDesktopDeployRecipeFile>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Platform)'=='x64'">
    <ExecutablePath>$(VCToolsInstallDir)bin\Hostx64\x64;$(ExecutablePath)</ExecutablePath>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Platform)'=='ARM64'">
    <ExecutablePath>$(VCToolsInstallDir)bin\Hostarm64\arm64;$(ExecutablePath)</ExecutablePath>
  </PropertyGroup>
  <PropertyGroup>
    <VC_LibraryPath_Enclave>$(VCToolsInstallDir)lib\$(Platform)\enclave</VC_LibraryPath_Enclave>
    <WindowsSDK_LibraryPath_Enclave>$(WindowsSDK_LibraryPath)\..\ucrt_enclave\$(Platform)</WindowsSDK_LibraryPath_Enclave>
    <VBS_Enclave_Dependencies>
      $(VC_LibraryPath_Enclave)\libcmt.lib;
      $(VC_LibraryPath_Enclave)\libvcruntime.lib;
      $(WindowsSDK_LibraryPath_Enclave)\ucrt.lib;
      vertdll.lib;
      bcrypt.lib;
    </VBS_Enclave_Dependencies>
  </PropertyGroup>
  <PropertyGroup Label="Enclave runtime library (must match the NuGet cpp support lib variant)">
    <TlsEnclaveRuntimeLibrary Condition="'$(Configuration)'=='Debug'">MultiThreadedDebug</TlsEnclaveRuntimeLibrary>
    <TlsEnclaveRuntimeLibrary Condition="'$(Configuration)'=='Release'">MultiThreaded</TlsEnclaveRuntimeLibrary>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <WarningLevel>Level3</WarningLevel>
      <SDLCheck>true</SDLCheck>
      <ConformanceMode>true</ConformanceMode>
      <PrecompiledHeader>NotUsing</PrecompiledHeader>
      <RuntimeLibrary>$(TlsEnclaveRuntimeLibrary)</RuntimeLibrary>
      <BasicRuntimeChecks>Default</BasicRuntimeChecks>
      <DebugInformationFormat>ProgramDatabase</DebugInformationFormat>
      <LanguageStandard>stdcpp20</LanguageStandard>
      <LanguageStandard_C>stdc17</LanguageStandard_C>
      <AdditionalIncludeDirectories>
        $(ProjectDir)..\Common;
        $(MbedTlsRoot)\include;
        %(AdditionalIncludeDirectories)
      </AdditionalIncludeDirectories>
      <PreprocessorDefinitions>
        WIN32_LEAN_AND_MEAN;
        NOMINMAX;
        MBEDTLS_CONFIG_FILE=&quot;TlsMbedTlsConfig.h&quot;;
        %(PreprocessorDefinitions)
      </PreprocessorDefinitions>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <EnableUAC>false</EnableUAC>
      <AdditionalDependencies>$(VBS_Enclave_Dependencies)</AdditionalDependencies>
      <AdditionalOptions>/INTEGRITYCHECK /ENCLAVE /GUARD:MIXED</AdditionalOptions>
      <IgnoreAllDefaultLibraries>true</IgnoreAllDefaultLibraries>
    </Link>
  </ItemDefinitionGroup>
  <ItemGroup>
    <ClCompile Include="dllmain.cpp" />
    <ClCompile Include="tls_enclave.cpp" />
    <ClCompile Include="..\Common\TlsMbedTlsDriver.cpp" />
    <ClCompile Include="$(MbedTlsRoot)\library\*.c" Exclude="$(MbedTlsRoot)\library\net_sockets.c;$(MbedTlsRoot)\library\timing.c;$(MbedTlsRoot)\library\psa_its_file.c" />
  </ItemGroup>
  <ItemGroup>
    <ClInclude Include="..\Common\TlsMbedTlsConfig.h" />
    <ClInclude Include="..\Common\TlsMbedTlsDriver.h" />
    <ClInclude Include="ScenarioPolicy.g.h" />
  </ItemGroup>
  <ItemGroup>
    <None Include="packages.config" />
  </ItemGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <ImportGroup Label="ExtensionTargets">
    <Import Project="..\packages\Microsoft.Windows.ImplementationLibrary.1.0.240803.1\build\native\Microsoft.Windows.ImplementationLibrary.targets" Condition="Exists('..\packages\Microsoft.Windows.ImplementationLibrary.1.0.240803.1\build\native\Microsoft.Windows.ImplementationLibrary.targets')" />
    <Import Project="..\packages\Microsoft.Windows.VbsEnclave.CodeGenerator.0.1.2-prerelease.250820.1\build\native\Microsoft.Windows.VbsEnclave.CodeGenerator.targets" Condition="Exists('..\packages\Microsoft.Windows.VbsEnclave.CodeGenerator.0.1.2-prerelease.250820.1\build\native\Microsoft.Windows.VbsEnclave.CodeGenerator.targets')" />
  </ImportGroup>
  <Target Name="EnsureNuGetPackageBuildImports" BeforeTargets="PrepareForBuild">
    <PropertyGroup>
      <ErrorText>This project references NuGet package(s) that are missing on this computer. Build Tls.sln (or run 'nuget restore') to restore them. The missing file is {0}.</ErrorText>
    </PropertyGroup>
    <Error Condition="!Exists('..\packages\Microsoft.Windows.ImplementationLibrary.1.0.240803.1\build\native\Microsoft.Windows.ImplementationLibrary.targets')" Text="$([System.String]::Format('$(ErrorText)', '..\packages\Microsoft.Windows.ImplementationLibrary.1.0.240803.1\build\native\Microsoft.Windows.ImplementationLibrary.targets'))" />
    <Error Condition="!Exists('..\packages\Microsoft.Windows.VbsEnclave.CodeGenerator.0.1.2-prerelease.250820.1\build\native\Microsoft.Windows.VbsEnclave.CodeGenerator.props')" Text="$([System.String]::Format('$(ErrorText)', '..\packages\Microsoft.Windows.VbsEnclave.CodeGenerator.0.1.2-prerelease.250820.1\build\native\Microsoft.Windows.VbsEnclave.CodeGenerator.props'))" />
    <Error Condition="!Exists('..\packages\Microsoft.Windows.VbsEnclave.CodeGenerator.0.1.2-prerelease.250820.1\build\native\Microsoft.Windows.VbsEnclave.CodeGenerator.targets')" Text="$([System.String]::Format('$(ErrorText)', '..\packages\Microsoft.Windows.VbsEnclave.CodeGenerator.0.1.2-prerelease.250820.1\build\native\Microsoft.Windows.VbsEnclave.CodeGenerator.targets'))" />
  </Target>
  <Target Name="EnsureMbedTlsSource" BeforeTargets="PrepareForBuild">
    <Error Condition="!Exists('$(MbedTlsRoot)\include\mbedtls\version.h')" Text="mbedTLS source was not found. Run ..\..\Fetch-MbedTls.ps1 first." />
  </Target>
  <!-- Fail fast with actionable guidance when the enclave signing certificate is missing. -->
  <Target Name="EnsureSigningCertificate" BeforeTargets="PrepareForBuild">
    <Exec Command="pwsh -NoProfile -Command &quot;if (Get-ChildItem Cert:\CurrentUser\My | Where-Object { $_.Subject -eq 'CN=$(EnclaveCertName)' }) { 'present' } else { 'missing' }&quot;" ConsoleToMSBuild="true" StandardOutputImportance="low">
      <Output TaskParameter="ConsoleOutput" PropertyName="_SigningCertState" />
    </Exec>
    <Error Condition="'$(_SigningCertState)' == 'missing'" Text="Enclave signing certificate 'CN=$(EnclaveCertName)' was not found in Cert:\CurrentUser\My. Run Add-TrustedSigningCert.ps1 (in SampleApps\Tls\Scripts) to create and trust it, then rebuild." />
  </Target>
  <!-- Regenerate the pinned-certificate policy header before compiling. -->
  <Target Name="GenerateScenarioPolicy" BeforeTargets="ClCompile">
    <Message Importance="high" Text="Generating enclave scenario policy pin (ScenarioPolicy.g.h)." />
    <Exec Command="pwsh -NoProfile -File &quot;$(ProjectDir)Generate-ScenarioPolicy.ps1&quot;" />
  </Target>
  <!-- Apply VEIID protection and sign the enclave image after the build. -->
  <Target Name="SignTlsEnclave" AfterTargets="Build">
    <PropertyGroup>
      <_EnclaveImage>$(OutDir)$(TargetName)$(TargetExt)</_EnclaveImage>
      <_SignArch Condition="'$(Platform)'=='ARM64'">arm64</_SignArch>
      <_SignArch Condition="'$(_SignArch)'==''">x64</_SignArch>
    </PropertyGroup>
    <Message Importance="high" Text="Applying VEIID protection and signing $(TargetName)$(TargetExt) with certificate 'CN=$(EnclaveCertName)'." />
    <Exec Command="pwsh -NoProfile -Command &quot;$ErrorActionPreference='Stop'; $kits=Join-Path ${env:ProgramFiles(x86)} 'Windows Kits\10\bin'; $dirs=Get-ChildItem $kits -Directory | Sort-Object Name -Descending; $find={param($n) $dirs | ForEach-Object { [IO.Path]::Combine($_.FullName,'$(_SignArch)',$n) } | Where-Object { Test-Path $_ } | Select-Object -First 1}; $veiid=&amp; $find 'veiid.exe'; $signtool=&amp; $find 'signtool.exe'; if (-not $veiid) { throw 'veiid.exe not found under ' + $kits }; if (-not $signtool) { throw 'signtool.exe not found under ' + $kits }; &amp; $veiid '$(_EnclaveImage)'; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; &amp; $signtool sign /ph /fd SHA256 /n '$(EnclaveCertName)' '$(_EnclaveImage)'; if ($LASTEXITCODE -ne 0 -and $LASTEXITCODE -ne 2) { exit $LASTEXITCODE }; exit 0&quot;" />
  </Target>
</Project>
